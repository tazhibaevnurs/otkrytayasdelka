# Скопируйте в .env и подставьте свои значения. Не коммитьте .env.
# Реальные ключи, пароли БД и API не храните в git.

# --- Django ---
# Обязательно в production (DEBUG=0 / Docker): случайная строка ≥ 50 символов.
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=0
# Для локальной разработки можно включить:
# DJANGO_DEBUG=1
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# База: либо SQLite (путь), либо PostgreSQL через URL (пароль только в .env, не в коде).
# DJANGO_DB_PATH=/path/to/db.sqlite3
# DATABASE_URL=postgresql://user:PASSWORD@host:5432/dbname

# DJANGO_MEDIA_ROOT=/path/to/media
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_SESSION_COOKIE_AGE=43200
# DJANGO_REGISTRATION_OPEN=0
# DJANGO_AUTH_PROTECTED_PREFIXES=/accounts/profile/

# Почта (пароль приложения — только здесь).
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_EMAIL_HOST=smtp.example.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_HOST_USER=
# DJANGO_EMAIL_HOST_PASSWORD=
# DJANGO_DEFAULT_FROM_EMAIL=noreply@example.com

# --- Публичный URL API для фронтенда (не секрет). Префиксы VITE_* / NEXT_PUBLIC_*
# в браузере видны всем — никогда не кладите туда JWT, service role, Stripe secret, Anthropic и т.д.
# VITE_API_URL=http://127.0.0.1:8000

# В проекте нет Next.js/Supabase/Stripe/ЮKassa/Anthropic; при добавлении храните секреты
# только в переменных сервера (Django settings / backend), не в NEXT_PUBLIC_* / VITE_*.

# Лимиты AI (заглушка POST /api/ai/generate/): free и pro (группа subscription_pro)
# AI_RATE_LIMIT_FREE_DAILY=5
# AI_RATE_LIMIT_PRO_DAILY=50
# AI_PRO_GROUP_NAME=subscription_pro

# --- HTTPS / HSTS / CORS (production) ---
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_HSTS_INCLUDE_SUBDOMAINS=1
# DJANGO_HSTS_PRELOAD=0
# Только ваши домены фронта, через запятую (без *)
# DJANGO_CORS_ALLOWED_ORIGINS=https://otkrytayasdelka.kg,https://www.otkrytayasdelka.kg
# Опционально: своя строка Content-Security-Policy
# DJANGO_CSP=
# Пороги мониторинга (логи security в JSON, stdout)
# DJANGO_SUSPICIOUS_AUTH_PER_MIN=30
# DJANGO_ANOMALY_RPM=400
